# Copy to Render / Fly.io secrets (do not commit real values)

PORT=8080
DEBUG=False
FLASK_ENV=production

JWT_SECRET=generate-a-long-random-string-min-32-chars
ADMIN_BOOTSTRAP_KEY=your-strong-admin-bootstrap-key
ADMIN_EMAILS=admin@solutionservices.co.in

ALLOWED_ORIGINS=https://solutionservices.co.in,https://www.solutionservices.co.in

JWT_EXPIRE_HOURS=168

# Persistent SQLite on Fly.io (volume mounted at /data)
DATABASE_PATH=/data/urban_services.db
